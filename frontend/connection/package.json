{
  "name": "@streamlit/connection",
  "version": "1.55.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/streamlit-connection.cjs.js",
  "module": "./dist/streamlit-connection.es.js",
  "browser": "./dist/streamlit-connection.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/streamlit-connection.es.js",
      "require": "./dist/streamlit-connection.cjs.js",
      "default": "./dist/streamlit-connection.umd.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "buildWatch": "env DEV_WATCH=1 vite build --watch",
    "test": "vitest run",
    "testWatch": "vitest",
    "lint": "yarn run -T eslint --cache --max-warnings 0 src",
    "lint:fix": "yarn run -T eslint --cache --max-warnings 0 --fix src",
    "typecheck": "yarn run typecheck:all",
    "format": "yarn run -T oxfmt --config ../.oxfmtrc.json './src/**/*.{js,ts,jsx,tsx}'",
    "formatCheck": "yarn run -T oxfmt --check --config ../.oxfmtrc.json './src/**/*.{js,ts,jsx,tsx}'",
    "typesync": "typesync",
    "typesync:ci": "typesync --dry=fail"
  },
  "dependencies": {
    "@streamlit/protobuf": "workspace:^",
    "@streamlit/utils": "workspace:^",
    "axios": "^1.13.6",
    "lodash-es": "^4.17.23",
    "loglevel": "^1.9.2"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "axios-mock-adapter": "^2.1.0",
    "typesync": "^0.14.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.1.0",
    "vitest": "^4.1.0",
    "vitest-websocket-mock": "^0.5.0"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}

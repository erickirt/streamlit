# Ignore everything by default
*

# Allow specific files
!.gitignore
!settings.json

# Allow specific hooks
!hooks/
hooks/*
!hooks/pre_bash_redirect.py
!hooks/stop_check.sh
!hooks/post_edit_autofix.sh

# Allow specific skills
!skills/
skills/*
!skills/AGENTS.md
!skills/CLAUDE.md
!skills/checking-changes/
!skills/debugging-streamlit/
!skills/discovering-make-commands/
!skills/finalizing-pr/
!skills/fixing-streamlit-ci/
!skills/implementing-new-features/
!skills/addressing-pr-review-comments/
!skills/creating-pull-requests/

# Allow agents
!agents/
agents/*
!agents/reviewing-local-changes.md
!agents/simplifying-local-changes.md
!agents/fixing-pr.md

# Allow commands
!commands/
commands/*
!commands/simplifying-local-changes.md
!commands/reviewing-local-changes.md
!commands/fixing-pr.md
